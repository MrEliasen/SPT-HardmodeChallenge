<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <RootNamespace>Vagabond.Server</RootNamespace>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <OutputType>Library</OutputType>
        <LangVersion>latest</LangVersion>
        <OutputPath>..\\build\\server\\$(Configuration)\\$(AssemblyName)\\</OutputPath>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <PackageId>Vagabond</PackageId>
    </PropertyGroup>

    <PropertyGroup>
        <TarkovDir Condition=" '$(TarkovDir)' == '' ">D:\SPT-dev\</TarkovDir>
        <TarkovPluginsSPTDir>$(TarkovDir)SPT\user\mods\</TarkovPluginsSPTDir>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="SPTarkov.Common" Version="4.0.13"/>
        <PackageReference Include="SPTarkov.DI" Version="4.0.13"/>
        <PackageReference Include="SPTarkov.Server.Core" Version="4.0.13"/>
        <PackageReference Include="SPTarkov.Reflection" Version="4.0.13"/>
        <ProjectReference Include="..\\common\\Vagabond.Common.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="Config\\vagabond.json" Link="config\\vagabond.json" CopyToOutputDirectory="Always"/>
    </ItemGroup>


    <Target Name="PostBuild" AfterTargets="Build">
        <ItemGroup>
            <OutputDLL Include="$(ProjectDir)$(OutDir)$(TargetName).dll"/>
        </ItemGroup>

        <ItemGroup>
            <PluginFiles Include="$(ProjectDir)$(OutDir)$(TargetName).dll"/>
            <PluginFiles Include="$(ProjectDir)$(OutDir)Vagabond.Common.dll"/>
        </ItemGroup>

        <!-- Copy to Tarkov plugin directory -->
        <Copy SourceFiles="@(PluginFiles)"
              DestinationFolder="$(TarkovPluginsSPTDir)Vagabond\"
              SkipUnchangedFiles="true"/>
    </Target>
</Project>
